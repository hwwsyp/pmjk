<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tpfh.fintech.modules.pmjk.productAttachment.dao.ProductAttachmentDao">

    <!--表所有的列名集合-->
    <sql id="allColumns">
            id,
            productid,
            type,
            filepath,
            url,
            srcname,
            destname,
            uploaduser,
            uploadtime    </sql>

    <!--除去主键id的所有列名集合-->
    <sql id="exceptIdColumns">
                productid,
                type,
                filepath,
                url,
                srcname,
                destname,
                uploaduser,
                uploadtime    </sql>
    
    <!-- 查询分页信息 -->
    <select id="getProductAttachmentListForPage" resultType="com.tpfh.fintech.modules.pmjk.productAttachment.entity.ProductAttachmentEntity">
		 select <include refid="allColumns"/> from pmjk_product_attachment
		<where>
          	<if test="id != null and id != ''"> and id=#{id}</if>
          	<if test="productid != null and productid != ''"> and productid=#{productid}</if>
          	<if test="type != null and type != ''"> and type=#{type}</if>
          	<if test="filepath != null and filepath != ''"> and filepath=#{filepath}</if>
          	<if test="url != null and url != ''"> and url=#{url}</if>
          	<if test="srcname != null and srcname != ''"> and srcname=#{srcname}</if>
          	<if test="destname != null and destname != ''"> and destname=#{destname}</if>
          	<if test="uploaduser != null and uploaduser != ''"> and uploaduser=#{uploaduser}</if>
          	<if test="uploadtime != null and uploadtime != ''"> and uploadtime=#{uploadtime}</if>
		</where>
		order by type
	</select>

    <!--查询符合条件的信息列表-->
    <select id="getProductAttachmentList" resultType="com.tpfh.fintech.modules.pmjk.productAttachment.entity.ProductAttachmentEntity">
        select <include refid="allColumns"/> from pmjk_product_attachment
        <where>
            <if test="id != null and id != ''"> and id=#{id}</if>
            <if test="productid != null and productid != ''"> and productid=#{productid}</if>
            <if test="type != null and type != ''"> and type=#{type}</if>
            <if test="filepath != null and filepath != ''"> and filepath=#{filepath}</if>
            <if test="url != null and url != ''"> and url=#{url}</if>
            <if test="srcname != null and srcname != ''"> and srcname=#{srcname}</if>
            <if test="destname != null and destname != ''"> and destname=#{destname}</if>
            <if test="uploaduser != null and uploaduser != ''"> and uploaduser=#{uploaduser}</if>
            <if test="uploadtime != null and uploadtime != ''"> and uploadtime=#{uploadtime}</if>
        </where>
        order by type
    </select>

	<!-- 新增实体信息 -->
    <insert id="addProductAttachment" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap">
        insert into pmjk_product_attachment (<include refid="exceptIdColumns"/>)
        values(
                #{productid},
                #{type},
                #{filepath},
                #{url},
                #{srcname},
                #{destname},
                #{uploaduser},
                #{uploadtime}        );
    </insert>

    
</mapper>