<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tpfh.fintech.modules.pmjk.productrisk.dao.ProductriskDao">

    <!--表所有的列名集合-->
    <sql id="allColumns">
            id,
            breif,
            status,
            preriskid,
            risklevel,
            productid,
            createtimestamp,
            updatetimestamp,
            submitter    </sql>

    <!--除去主键id的所有列名集合-->
    <sql id="exceptIdColumns">
                breif,
                status,
                preriskid,
                risklevel,
                productid,
                createtimestamp,
                updatetimestamp,
                submitter    </sql>
    
    <!-- 查询分页信息 -->
    <select id="getProductriskListForPage" resultType="com.tpfh.fintech.modules.pmjk.productrisk.entity.ProductriskEntity">
		 select <include refid="allColumns"/> from pmjk_productrisk
		<where>
          	<if test="id != null and id != ''"> and id=#{id}</if>
          	<if test="breif != null and breif != ''"> and breif=#{breif}</if>
          	<if test="status != null and status != ''"> and status=#{status}</if>
          	<if test="preriskid != null and preriskid != ''"> and preriskid=#{preriskid}</if>
          	<if test="risklevel != null and risklevel != ''"> and risklevel=#{risklevel}</if>
          	<if test="productid != null and productid != ''"> and productid=#{productid}</if>
          	<if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
          	<if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
          	<if test="submitter != null and submitter != ''"> and submitter=#{submitter}</if>
		</where>
	</select>

    <!--查询符合条件的信息列表-->
    <select id="getProductriskList" resultType="com.tpfh.fintech.modules.pmjk.productrisk.entity.ProductriskEntity">
        select <include refid="allColumns"/> from pmjk_productrisk
        <where>
            <if test="id != null and id != ''"> and id=#{id}</if>
            <if test="breif != null and breif != ''"> and breif=#{breif}</if>
            <if test="status != null and status != ''"> and status=#{status}</if>
            <if test="preriskid != null and preriskid != ''"> and preriskid=#{preriskid}</if>
            <if test="risklevel != null and risklevel != ''"> and risklevel=#{risklevel}</if>
            <if test="productid != null and productid != ''"> and productid=#{productid}</if>
            <if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
            <if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
            <if test="submitter != null and submitter != ''"> and submitter=#{submitter}</if>
        </where>
    </select>

	<!-- 新增实体信息 -->
    <insert id="addProductrisk" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap">
        insert into pmjk_productrisk (<include refid="exceptIdColumns"/>)
        values(
                #{breif},
                #{status},
                #{preriskid},
                #{risklevel},
                #{productid},
                #{createtimestamp},
                #{updatetimestamp},
                #{submitter}        );
    </insert>

    
</mapper>