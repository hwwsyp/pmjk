<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tpfh.fintech.modules.pmjk.rating.dao.RatingDao">

    <!--表所有的列名集合-->
    <sql id="allColumns">
            id,
            lev, 
            ratinguser,
            ratingtype,
            ratingtx,
            bodytype,
            bodyname,
            productid,
            targettype,
            createtimestamp,
            updatetimestamp,
            orgid,
            ratingdate,
            saveflag,
            historyflag    </sql>

    <!--除去主键id的所有列名集合-->
    <sql id="exceptIdColumns">
                lev, 
                ratinguser,
                ratingtype,
                ratingtx,
                bodytype,
                bodyname,
                productid,
                targettype,
                createtimestamp,
                updatetimestamp,
                orgid,
                ratingdate,
                saveflag,
                historyflag    </sql>
    
    <!-- 查询分页信息 -->
    <select id="getRatingListForPage" resultType="com.tpfh.fintech.modules.pmjk.rating.entity.RatingEntity">
		 select <include refid="allColumns"/> from pmjk_rating
		<where>
          	<if test="id != null and id != ''"> and id=#{id}</if>
          	<if test="lev != null and lev != ''"> and lev=#{lev}</if> 
          	<if test="ratinguser != null and ratinguser != ''"> and ratinguser=#{ratinguser}</if>
          	<if test="ratingtype != null and ratingtype != ''"> and ratingtype=#{ratingtype}</if>
          	<if test="ratingtx != null and ratingtx != ''"> and ratingtx=#{ratingtx}</if>
          	<if test="bodytype != null and bodytype != ''"> and bodytype=#{bodytype}</if>
          	<if test="bodyname != null and bodyname != ''"> and bodyname=#{bodyname}</if>
          	<if test="productid != null and productid != ''"> and productid=#{productid}</if>
          	<if test="targettype != null and targettype != ''"> and targettype=#{targettype}</if>
          	<if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
          	<if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
          	<if test="orgid != null and orgid != ''"> and orgid=#{orgid}</if>
          	<if test="ratingdate != null and ratingdate != ''"> and ratingdate=#{ratingdate}</if>
          	<if test="saveflag != null and saveflag != ''"> and saveflag=#{saveflag}</if>
          	<if test="historyflag != null and historyflag != ''"> and historyflag=#{historyflag}</if>
		</where>
	</select>

    <!--查询符合条件的信息列表-->
    <select id="getRatingList" resultType="com.tpfh.fintech.modules.pmjk.rating.entity.RatingEntity">
        select <include refid="allColumns"/> from pmjk_rating
        <where>
            <if test="id != null and id != ''"> and id=#{id}</if>
            <if test="lev != null and lev != ''"> and lev=#{lev}</if> 
            <if test="ratinguser != null and ratinguser != ''"> and ratinguser=#{ratinguser}</if>
            <if test="ratingtype != null and ratingtype != ''"> and ratingtype=#{ratingtype}</if>
            <if test="ratingtx != null and ratingtx != ''"> and ratingtx=#{ratingtx}</if>
            <if test="bodytype != null and bodytype != ''"> and bodytype=#{bodytype}</if>
            <if test="bodyname != null and bodyname != ''"> and bodyname=#{bodyname}</if>
            <if test="productid != null and productid != ''"> and productid=#{productid}</if>
            <if test="targettype != null and targettype != ''"> and targettype=#{targettype}</if>
            <if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
            <if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
            <if test="orgid != null and orgid != ''"> and orgid=#{orgid}</if>
            <if test="ratingdate != null and ratingdate != ''"> and ratingdate=#{ratingdate}</if>
            <if test="saveflag != null and saveflag != ''"> and saveflag=#{saveflag}</if>
            <if test="historyflag != null and historyflag != ''"> and historyflag=#{historyflag}</if>
        </where>
    </select>

	<!-- 新增实体信息 -->
    <insert id="addRating" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap">
        insert into pmjk_rating (<include refid="exceptIdColumns"/>)
        values(
                #{lev}, 
                #{ratinguser},
                #{ratingtype},
                #{ratingtx},
                #{bodytype},
                #{bodyname},
                #{productid},
                #{targettype},
                #{createtimestamp},
                #{updatetimestamp},
                #{orgid},
                #{ratingdate},
                #{saveflag},
                #{historyflag}        );
    </insert>

    
</mapper>