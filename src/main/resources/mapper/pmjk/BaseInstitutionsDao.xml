<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tpfh.fintech.modules.pmjk.baseInstitutions.dao.BaseInstitutionsDao">

    <!--表所有的列名集合-->
    <sql id="allColumns">
            id,
            name,
            institutionstype,
            swcode,
            gicscode,
            countrycode,
            isgroupcustomer    </sql>

    <!--除去主键id的所有列名集合-->
    <sql id="exceptIdColumns">
                name,
                institutionstype,
                swcode,
                gicscode,
                countrycode,
                isgroupcustomer    </sql>
    
    <!-- 查询分页信息 -->
    <select id="getBaseInstitutionsListForPage" resultType="com.tpfh.fintech.modules.pmjk.baseInstitutions.entity.BaseInstitutionsEntity">
		 select <include refid="allColumns"/> from pmjk_base_institutions
		<where>
          	<if test="id != null and id != ''"> and id=#{id}</if>
          	<if test="name != null and name != ''"> and name like  '%' || #{name} ||'%'</if>
          	<if test="institutionstype != null and institutionstype != ''"> and institutionstype=#{institutionstype}</if>
          	<if test="swcode != null and swcode != ''"> and swcode=#{swcode}</if>
          	<if test="gicscode != null and gicscode != ''"> and gicscode=#{gicscode}</if>
          	<if test="countrycode != null and countrycode != ''"> and countrycode=#{countrycode}</if>
          	<if test="isgroupcustomer != null and isgroupcustomer != ''"> and isgroupcustomer=#{isgroupcustomer}</if>
		</where>
	</select>

    <!--查询符合条件的信息列表-->
    <select id="getBaseInstitutionsList" resultType="com.tpfh.fintech.modules.pmjk.baseInstitutions.entity.BaseInstitutionsEntity">
        select <include refid="allColumns"/> from pmjk_base_institutions
        <where>
            <if test="id != null and id != ''"> and id=#{id}</if>
            <if test="name != null and name != ''"> and name=#{name}</if>
            <if test="institutionstype != null and institutionstype != ''"> and institutionstype=#{institutionstype}</if>
            <if test="swcode != null and swcode != ''"> and swcode=#{swcode}</if>
            <if test="gicscode != null and gicscode != ''"> and gicscode=#{gicscode}</if>
            <if test="countrycode != null and countrycode != ''"> and countrycode=#{countrycode}</if>
            <if test="isgroupcustomer != null and isgroupcustomer != ''"> and isgroupcustomer=#{isgroupcustomer}</if>
        </where>
    </select>

	<!-- 新增实体信息 -->
    <insert id="addBaseInstitutions" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap">
        insert into pmjk_base_institutions (<include refid="exceptIdColumns"/>)
        values(
                #{name},
                #{institutionstype},
                #{swcode},
                #{gicscode},
                #{countrycode},
                #{isgroupcustomer}        );
    </insert>

    
</mapper>