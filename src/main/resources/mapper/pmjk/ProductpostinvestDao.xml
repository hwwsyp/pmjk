<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tpfh.fintech.modules.pmjk.productpostinvest.dao.ProductpostinvestDao">

    <!--表所有的列名集合-->
    <sql id="allColumns">
            id,
            productid,
            matter,
            matterremark,
            createtimestamp,
            updatetimestamp,
            submitter    </sql>

    <!--除去主键id的所有列名集合-->
    <sql id="exceptIdColumns">
                productid,
                matter,
                matterremark,
                createtimestamp,
                updatetimestamp,
                submitter    </sql>
    
    <!-- 查询分页信息 -->
    <select id="getProductpostinvestListForPage" resultType="com.tpfh.fintech.modules.pmjk.productpostinvest.entity.ProductpostinvestEntity">
		 select <include refid="allColumns"/> from pmjk_productpostinvest
		<where>
          	<if test="id != null and id != ''"> and id=#{id}</if>
          	<if test="productid != null and productid != ''"> and productid=#{productid}</if>
          	<if test="matter != null and matter != ''"> and matter=#{matter}</if>
          	<if test="matterremark != null and matterremark != ''"> and matterremark=#{matterremark}</if>
          	<if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
          	<if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
          	<if test="submitter != null and submitter != ''"> and submitter=#{submitter}</if>
		</where>
	</select>

    <!--查询符合条件的信息列表-->
    <select id="getProductpostinvestList" resultType="com.tpfh.fintech.modules.pmjk.productpostinvest.entity.ProductpostinvestEntity">
        select <include refid="allColumns"/> from pmjk_productpostinvest
        <where>
            <if test="id != null and id != ''"> and id=#{id}</if>
            <if test="productid != null and productid != ''"> and productid=#{productid}</if>
            <if test="matter != null and matter != ''"> and matter=#{matter}</if>
            <if test="matterremark != null and matterremark != ''"> and matterremark=#{matterremark}</if>
            <if test="createtimestamp != null and createtimestamp != ''"> and createtimestamp=#{createtimestamp}</if>
            <if test="updatetimestamp != null and updatetimestamp != ''"> and updatetimestamp=#{updatetimestamp}</if>
            <if test="submitter != null and submitter != ''"> and submitter=#{submitter}</if>
        </where>
    </select>

	<!-- 新增实体信息 -->
    <insert id="addProductpostinvest" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap">
        insert into pmjk_productpostinvest (<include refid="exceptIdColumns"/>)
        values(
                #{productid},
                #{matter},
                #{matterremark},
                #{createtimestamp},
                #{updatetimestamp},
                #{submitter}        );
    </insert>

    
</mapper>